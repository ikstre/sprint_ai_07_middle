### 시나리오 B: OpenAI API ###
OPENAI_API_KEY=sk-proj-...

### 시나리오 A: HuggingFace ###
# HuggingFace Hub 토큰 (비공개 모델 사용 시 필요, https://huggingface.co/settings/tokens)
HF_TOKEN=hf_...

### AutoRAG 전용 인터프리터 ###
# AutoRAG는 openai<2.0 생태계를 요구하므로 별도 conda 환경 사용
# conda create -n autorag python=3.11 && pip install -r requirements-autorag.txt
# Windows: C:\ProgramData\anaconda3\envs\autorag\python.exe
# Linux:   /opt/conda/envs/autorag/bin/python
AUTORAG_PYTHON=C:\ProgramData\anaconda3\envs\autorag\python.exe
