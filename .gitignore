# Secrets / local env
.env
.env.local
.env.*.local
myenv/

# Raw input data (default: do not commit)
!data/
data/*
!data/.gitkeep

# Selected processed data that may be committed for reproducibility
!data/data_list_cleaned.csv
!data/autorag_csv_600/
!data/autorag_csv_600/corpus.parquet
!data/autorag_csv_600/qa.parquet
!data/autorag_csv_800/
!data/autorag_csv_800/corpus.parquet
!data/autorag_csv_800/qa.parquet
!data/autorag_csv_1000/
!data/autorag_csv_1000/corpus.parquet
!data/autorag_csv_1000/qa.parquet
!data/autorag_csv_1200/
!data/autorag_csv_1200/corpus.parquet
!data/autorag_csv_1200/qa.parquet
!data/processed/
!data/processed/rfp_chunk600_chunks.json
!data/processed/rfp_chunk800_chunks.json
!data/processed/rfp_chunk1000_chunks.json
!data/processed/rfp_chunk1200_chunks.json

# Vector DB / indexes
chroma_db/
data/vectordb/

# Evaluation outputs (default: do not commit)
!evaluation/
/evaluation/*

# Final evaluation artifacts that may be committed
!evaluation/b_chunk600_full_core_v2/
!evaluation/b_chunk600_full_core_v2/**
!evaluation/b_chunk800_full_core_v2/
!evaluation/b_chunk800_full_core_v2/**

# Finetuned model weights (large binary files — use NAS or shared storage)
models/finetuned/

# AutoRAG 파이프라인 자동 생성 config (경로 치환된 임시 파일)
configs/autorag/local_csv_pipeline.yaml
configs/autorag/local_csv_pipeline_gemma.yaml

# Local shared data (models, datasets — use NAS or shared storage)
shared_data/

# CUDA installer
cuda-keyring*.deb

# Python cache
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
evaluation/eval_results.json

# Logs
*.log
