### 시나리오 B: OpenAI API ###
OPENAI_API_KEY=sk-proj-...

### 시나리오 A: HuggingFace 로컬 모델 ###
# /srv/shared_data/models/ 의 로컬 모델 사용 시 HF_TOKEN 불필요.
# HuggingFace Hub 비공개 모델을 직접 다운로드할 경우에만 설정.
# HF_TOKEN=hf_...

# 사용 가능한 로컬 모델 목록 (/srv/shared_data/models/)
#   임베딩:
#     /srv/shared_data/models/embeddings/BGE-m3-ko          (2.2G, 1024-dim, 한국어 특화)
#     /srv/shared_data/models/embeddings/ko-sroberta-multitask (846M, 768-dim, 경량)
#
#   채팅:
#     /srv/shared_data/models/exaone/EXAONE-4.0-1.2B        (2.4G, 빠름)
#     /srv/shared_data/models/exaone/EXAONE-Deep-2.4B       (4.5G, 균형)
#     /srv/shared_data/models/exaone/EXAONE-3.5-7.8B        (30G,  고성능)
#     /srv/shared_data/models/exaone/EXAONE-Deep-7.8B       (15G,  고성능)
#     /srv/shared_data/models/qwen/Qwen3-8B                 (16G,  다국어)
#     /srv/shared_data/models/gemma/Gemma3-4B               (8.1G, 다국어)
#     /srv/shared_data/models/kanana/kanana-nano-2.1b        (4.0G, 경량)
#     /srv/shared_data/models/kanana/kanana-1.5-2.1b         (4.4G, 경량)
#     /srv/shared_data/models/midm/Midm-2.0-Mini             (4.4G, 경량)

### AutoRAG 전용 인터프리터 ###
# AutoRAG는 openai<2.0 생태계를 요구하므로 별도 conda 환경 사용
# conda create -n autorag python=3.11 && pip install -r requirements-autorag.txt
# Windows: C:\ProgramData\anaconda3\envs\autorag\python.exe
# Linux:   /opt/conda/envs/autorag/bin/python
AUTORAG_PYTHON=C:\ProgramData\anaconda3\envs\autorag\python.exe
